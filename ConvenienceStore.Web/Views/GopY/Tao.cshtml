@model ConvenienceStore.Web.ViewModels.TaoGopYViewModel

@{
    ViewData["Title"] = "Góp ý";
}

<div class="container py-4">
    <div class="admin-form-card">
        <div class="admin-page-header mb-4">
            <div>
                <h2>Gửi góp ý</h2>
                <p>Khách hàng có thể góp ý về sản phẩm hoặc nhân viên.</p>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="Tao" method="post">
            <div class="mb-3">
                <label class="form-label">Loại góp ý</label>
                <select asp-for="LoaiGopY" class="form-select admin-input" id="loaiGopY">
                    <option value="1">Góp ý về sản phẩm</option>
                    <option value="2">Góp ý về nhân viên</option>
                </select>
            </div>

            <div class="mb-3" id="khoiSanPham">
                <label class="form-label">Sản phẩm</label>
                <select asp-for="SanPhamId" asp-items="Model.DanhSachSanPham" class="form-select admin-input">
                    <option value="">-- Chọn sản phẩm --</option>
                </select>
                <span asp-validation-for="SanPhamId" class="text-danger"></span>
            </div>

            <div class="mb-3 d-none" id="khoiNhanVien">
                <label class="form-label">Nhân viên</label>
                <select asp-for="NhanVienId" asp-items="Model.DanhSachNhanVien" class="form-select admin-input">
                    <option value="">-- Chọn nhân viên --</option>
                </select>
                <span asp-validation-for="NhanVienId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TieuDe" class="form-label">Tiêu đề</label>
                <input asp-for="TieuDe" class="form-control admin-input" />
                <span asp-validation-for="TieuDe" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NoiDung" class="form-label">Nội dung góp ý</label>
                <textarea asp-for="NoiDung" class="form-control admin-input" rows="5"></textarea>
                <span asp-validation-for="NoiDung" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn admin-primary-btn">Gửi góp ý</button>
                <a asp-controller="Home" asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const loaiGopY = document.getElementById("loaiGopY");
        const khoiSanPham = document.getElementById("khoiSanPham");
        const khoiNhanVien = document.getElementById("khoiNhanVien");

        function capNhatForm() {
            if (loaiGopY.value === "1") {
                khoiSanPham.classList.remove("d-none");
                khoiNhanVien.classList.add("d-none");
            } else {
                khoiSanPham.classList.add("d-none");
                khoiNhanVien.classList.remove("d-none");
            }
        }

        loaiGopY.addEventListener("change", capNhatForm);
        capNhatForm();
    </script>
}
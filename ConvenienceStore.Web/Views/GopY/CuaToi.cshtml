@model IEnumerable<ConvenienceStore.Models.Entities.GopY>
@using ConvenienceStore.Models.Enums

@{
    ViewData["Title"] = "Góp ý của tôi";
}

<div class="container py-4">
    <div class="admin-form-card">
        <div class="admin-page-header mb-4">
            <div>
                <h2>Góp ý của tôi</h2>
                <p>Theo dõi các góp ý đã gửi và phản hồi từ cửa hàng</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Loại góp ý</th>
                        <th>Tiêu đề</th>
                        <th>Đối tượng</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.Id</td>
                                <td>
                                    @if (item.LoaiGopY == LoaiGopY.SanPham)
                                    {
                                        <span class="badge bg-success">Sản phẩm</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Nhân viên</span>
                                    }
                                </td>
                                <td>@item.TieuDe</td>
                                <td>
                                    @if (item.LoaiGopY == LoaiGopY.SanPham)
                                    {
                                        @item.SanPham?.TenSanPham
                                    }
                                    else
                                    {
                                        @(item.NhanVien != null ? $"{item.NhanVien.MaNhanVien} - {item.NhanVien.HoTen}" : "")
                                    }
                                </td>
                                <td>@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a asp-action="ChiTiet" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Bạn chưa gửi góp ý nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
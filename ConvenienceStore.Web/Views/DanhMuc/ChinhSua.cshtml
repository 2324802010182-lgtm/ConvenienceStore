@model ConvenienceStore.Models.Entities.DanhMuc

@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-form-card">
    <div class="admin-page-header mb-4">
        <div>
            <h2>Chỉnh sửa danh mục</h2>
            <p>Cập nhật thông tin danh mục</p>
        </div>
    </div>

    <form asp-action="ChinhSua" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="TenDanhMuc" class="form-label">Tên danh mục</label>
            <input asp-for="TenDanhMuc" class="form-control admin-input" />
            <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MoTa" class="form-label">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control admin-input" rows="4"></textarea>
        </div>

        <div class="form-check mb-4">
            <input asp-for="TrangThai" class="form-check-input" />
            <label asp-for="TrangThai" class="form-check-label">Hoạt động</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn admin-primary-btn">Cập nhật</button>
            <a asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
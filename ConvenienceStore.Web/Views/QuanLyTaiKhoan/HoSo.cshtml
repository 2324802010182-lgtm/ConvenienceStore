@model ConvenienceStore.Web.ViewModels.CapNhatHoSoViewModel

@{
    ViewData["Title"] = "Hồ sơ";
}

<div class="account-page">
    <div class="container">
        <div class="account-shell">
            <div>
                <partial name="_MenuQuanLyTaiKhoan" />
            </div>

            <div class="section-card">
                <div class="section-head">
                    <div>
                        <h3 class="section-title">Hồ sơ cá nhân</h3>
                        <p class="section-subtitle">Cập nhật thông tin tài khoản của bạn</p>
                    </div>
                </div>

                <div class="section-body">
                    <div class="form-shell">
                        @if (TempData["ThanhCong"] != null)
                        {
                            <div class="alert alert-success rounded-4">@TempData["ThanhCong"]</div>
                        }

                        <form asp-action="HoSo" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="HoTen" class="form-label form-label-modern"></label>
                                <input asp-for="HoTen" class="form-control form-control-modern" />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label form-label-modern"></label>
                                <input asp-for="Email" class="form-control form-control-modern readonly-box" disabled />
                            </div>

                            <div class="mb-3">
                                <label asp-for="SoDienThoai" class="form-label form-label-modern"></label>
                                <input asp-for="SoDienThoai" class="form-control form-control-modern" />
                                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="DiaChi" class="form-label form-label-modern"></label>
                                <textarea asp-for="DiaChi" class="form-control form-textarea-modern"></textarea>
                                <span asp-validation-for="DiaChi" class="text-danger"></span>
                            </div>

                            <button type="submit" class="primary-btn">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Lưu thay đổi
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
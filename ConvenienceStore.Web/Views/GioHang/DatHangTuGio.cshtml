@model ConvenienceStore.Web.ViewModels.DatHangTuGioViewModel

@{
    ViewData["Title"] = "Đặt hàng từ giỏ";

    var diemToiDaTheoTongTien = (int)Math.Floor(Model.TongTien / 1000m);
    var diemToiDaDuocDung = Math.Min(Model.DiemHienCo, diemToiDaTheoTongTien);
}

<div class="container py-4">
    <div class="mb-4">
        <h2>Đặt hàng từ giỏ hàng</h2>
        <p class="text-muted">Xác nhận thông tin đơn hàng của bạn</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="auth-card" style="max-width: 100%;">
                <form asp-action="DatHangTuGio" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="HoTenNguoiNhan" class="form-label fw-semibold">
                            Họ tên người nhận
                        </label>
                        <input asp-for="HoTenNguoiNhan" class="form-control auth-input" />
                        <span asp-validation-for="HoTenNguoiNhan" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SoDienThoai" class="form-label fw-semibold">
                            Số điện thoại
                        </label>
                        <input asp-for="SoDienThoai" class="form-control auth-input" />
                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DiaChiNhanHang" class="form-label fw-semibold">
                            Địa chỉ nhận hàng
                        </label>
                        <textarea asp-for="DiaChiNhanHang"
                                  class="form-control auth-input"
                                  rows="3"></textarea>
                        <span asp-validation-for="DiaChiNhanHang" class="text-danger"></span>
                    </div>

                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="mb-3">Điểm tích lũy</h5>

                            <div class="mb-2">
                                Điểm hiện có:
                                <strong>@Model.DiemHienCo điểm</strong>
                            </div>

                            <div class="mb-2">
                                Có thể quy đổi:
                                <strong>@((Model.DiemHienCo * 1000).ToString("N0")) đ</strong>
                            </div>

                            <div class="mb-3">
                                Điểm tối đa có thể dùng cho đơn này:
                                <strong>@diemToiDaDuocDung điểm</strong>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DiemMuonDoi" class="form-label fw-semibold">
                                    Số điểm muốn dùng
                                </label>

                                <input asp-for="DiemMuonDoi"
                                       name="DiemMuonDoi"
                                       id="diemMuonDoi"
                                       type="number"
                                       class="form-control auth-input"
                                       min="0"
                                       max="@diemToiDaDuocDung"
                                       data-tong-tien="@Model.TongTien.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       data-diem-toi-da="@diemToiDaDuocDung" />

                                <span asp-validation-for="DiemMuonDoi" class="text-danger"></span>
                            </div>

                            <small class="text-muted">
                                Quy đổi: 1 điểm = 1.000đ. Cứ 10.000đ thanh toán được cộng 1 điểm.
                            </small>
                        </div>
                    </div>

                    <button type="submit" class="btn auth-btn w-100">
                        Xác nhận đặt hàng
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="admin-form-card">
                <h4 class="mb-3">Sản phẩm trong giỏ</h4>

                @foreach (var item in Model.DanhSachSanPham)
                {
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2 gap-3">
                        <div>
                            <div class="fw-semibold">@item.TenSanPham</div>
                            <small class="text-muted">Số lượng: @item.SoLuong</small>
                        </div>

                        <div class="fw-bold">
                            @item.ThanhTien.ToString("N0") đ
                        </div>
                    </div>
                }

                <div class="pt-3 mt-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Tổng tiền</strong>
                        <strong id="tongTienText">
                            @Model.TongTien.ToString("N0") đ
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Giảm từ điểm</span>
                        <strong id="giamTuDiemText" class="text-danger">
                            -0 đ
                        </strong>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between align-items-center">
                        <strong>Cần thanh toán</strong>
                        <strong id="canThanhToanText" style="color:#198754; font-size:18px;">
                            @Model.TongTien.ToString("N0") đ
                        </strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputDiem = document.getElementById("diemMuonDoi");
            const giamTuDiemText = document.getElementById("giamTuDiemText");
            const canThanhToanText = document.getElementById("canThanhToanText");

            if (!inputDiem || !giamTuDiemText || !canThanhToanText) {
                return;
            }

            const tongTien = Number(inputDiem.dataset.tongTien || 0);
            const diemToiDa = Number(inputDiem.dataset.diemToiDa || 0);

            function formatMoney(value) {
                return Math.round(value).toLocaleString("vi-VN") + " đ";
            }

            function capNhatTongTien() {
                let diemMuonDoi = Number(inputDiem.value || 0);

                if (isNaN(diemMuonDoi) || diemMuonDoi < 0) {
                    diemMuonDoi = 0;
                }

                if (diemMuonDoi > diemToiDa) {
                    diemMuonDoi = diemToiDa;
                }

                inputDiem.value = diemMuonDoi;

                let tienGiam = diemMuonDoi * 1000;

                if (tienGiam > tongTien) {
                    tienGiam = tongTien;
                }

                const tongTienSauGiam = tongTien - tienGiam;

                giamTuDiemText.innerText = "-" + formatMoney(tienGiam);
                canThanhToanText.innerText = formatMoney(tongTienSauGiam);
            }

            inputDiem.addEventListener("input", capNhatTongTien);
            inputDiem.addEventListener("change", capNhatTongTien);

            capNhatTongTien();
        });
    </script>
}
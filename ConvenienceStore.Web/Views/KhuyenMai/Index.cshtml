@model IEnumerable<ConvenienceStore.Web.ViewModels.KhuyenMaiViewModel>

@{
    ViewData["Title"] = "Khuyến mãi";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Quản lý khuyến mãi</h2>
        <p>Thiết lập giảm giá cho sản phẩm</p>
    </div>
</div>

@if (TempData["ThanhCong"] != null)
{
    <div class="alert alert-success">@TempData["ThanhCong"]</div>
}

<div class="admin-table-card">
    <table class="table admin-table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Tên sản phẩm</th>
                <th>Giá gốc</th>
                <th>Giảm giá</th>
                <th>Giá sau giảm</th>
                <th>Thời gian</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.TenSanPham</td>
                    <td>@item.GiaGoc.ToString("N0") đ</td>
                    <td>
                        @if (item.PhanTramGiam > 0)
                        {
                            <span class="status-badge status-warning">-@item.PhanTramGiam%</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Không</span>
                        }
                    </td>
                    <td>@item.GiaSauGiam.ToString("N0") đ</td>
                    <td>
                        @if (item.NgayBatDauKhuyenMai.HasValue && item.NgayKetThucKhuyenMai.HasValue)
                        {
                            <div>@item.NgayBatDauKhuyenMai.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            <div>đến @item.NgayKetThucKhuyenMai.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        }
                        else
                        {
                            <span class="text-muted">Chưa thiết lập</span>
                        }
                    </td>
                    <td>
                        @if (item.DangKhuyenMai)
                        {
                            <span class="status-badge status-active">Đang khuyến mãi</span>
                        }
                        else if (item.PhanTramGiam > 0)
                        {
                            <span class="status-badge status-inactive">Chưa hiệu lực / hết hạn</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Không khuyến mãi</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="ChinhSua" asp-route-id="@item.Id" class="btn admin-warning-btn btn-sm">Thiết lập</a>

                        @if (item.PhanTramGiam > 0)
                        {
                            <form asp-action="HuyKhuyenMai" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn admin-danger-btn btn-sm">Hủy</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
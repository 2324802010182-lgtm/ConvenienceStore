@model ConvenienceStore.Web.ViewModels.KhuyenMaiViewModel

@{
    ViewData["Title"] = "Thiết lập khuyến mãi";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-form-card">
    <div class="admin-page-header mb-4">
        <div>
            <h2>Thiết lập khuyến mãi</h2>
            <p>Cập nhật giảm giá cho sản phẩm</p>
        </div>
    </div>

    <form asp-action="ChinhSua" method="post">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Tên sản phẩm</label>
            <input value="@Model.TenSanPham" class="form-control admin-input" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Giá gốc</label>
            <input value="@Model.GiaGoc.ToString("N0") đ" class="form-control admin-input" readonly />
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="PhanTramGiam" class="form-label">Phần trăm giảm (%)</label>
                <input asp-for="PhanTramGiam" class="form-control admin-input" min="0" max="100" />
                <span asp-validation-for="PhanTramGiam" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="NgayBatDauKhuyenMai" class="form-label">Ngày bắt đầu</label>
                <input asp-for="NgayBatDauKhuyenMai" type="datetime-local" class="form-control admin-input" />
                <span asp-validation-for="NgayBatDauKhuyenMai" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="NgayKetThucKhuyenMai" class="form-label">Ngày kết thúc</label>
                <input asp-for="NgayKetThucKhuyenMai" type="datetime-local" class="form-control admin-input" />
                <span asp-validation-for="NgayKetThucKhuyenMai" class="text-danger"></span>
            </div>
        </div>

        @if (Model.PhanTramGiam > 0)
        {
            <div class="alert alert-info">
                Giá sau giảm dự kiến:
                <strong>@(Model.GiaGoc - (Model.GiaGoc * Model.PhanTramGiam / 100m)).ToString("N0") đ</strong>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn admin-primary-btn">Lưu khuyến mãi</button>
            <a asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model ConvenienceStore.Web.ViewModels.ChiTietDonHangAdminViewModel

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Chi tiết đơn hàng #@Model.Id</h2>
        <p>Thông tin và trạng thái đơn hàng</p>
    </div>
    <a asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
</div>

@if (TempData["ThanhCong"] != null)
{
    <div class="alert alert-success">@TempData["ThanhCong"]</div>
}

<div class="admin-form-card mb-4">
    <div class="row">
        <div class="col-md-6 mb-3">
            <strong>Người nhận:</strong> @Model.HoTenNguoiNhan
        </div>
        <div class="col-md-6 mb-3">
            <strong>Số điện thoại:</strong> @Model.SoDienThoai
        </div>
        <div class="col-md-6 mb-3">
            <strong>Email người đặt:</strong> @Model.EmailNguoiDat
        </div>
        <div class="col-md-6 mb-3">
            <strong>Ngày đặt:</strong> @Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")
        </div>
        <div class="col-12 mb-3">
            <strong>Địa chỉ nhận hàng:</strong> @Model.DiaChiNhanHang
        </div>
        <div class="col-md-6">
            <strong>Tổng tiền:</strong> @Model.TongTien.ToString("N0") đ
        </div>
        <div class="col-md-6">
            <strong>Trạng thái hiện tại:</strong> @Model.TrangThai
        </div>
    </div>
</div>

<div class="admin-form-card mb-4">
    <h4 class="mb-3">Cập nhật trạng thái</h4>

    <form asp-action="CapNhatTrangThai" method="post" class="row g-3">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="col-md-6">
            <select name="trangThai" class="form-select admin-input" asp-items="ViewBag.DanhSachTrangThai"></select>
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn admin-primary-btn">Cập nhật</button>
        </div>
    </form>
</div>

<div class="admin-table-card">
    <h4 class="mb-3">Sản phẩm trong đơn</h4>

    <table class="table admin-table align-middle">
        <thead>
            <tr>
                <th>Tên sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DanhSachSanPham)
            {
                <tr>
                    <td>@item.TenSanPham</td>
                    <td>@item.SoLuong</td>
                    <td>@item.DonGia.ToString("N0") đ</td>
                    <td>@item.ThanhTien.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@model IEnumerable<ConvenienceStore.Web.ViewModels.DonHangAdminViewModel>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Quản lý đơn hàng</h2>
        <p>Danh sách các đơn hàng trong hệ thống</p>
    </div>
</div>

<div class="admin-table-card">
    <table class="table admin-table align-middle">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Người nhận</th>
                <th>Email người đặt</th>
                <th>Số điện thoại</th>
                <th>Tổng tiền</th>
                <th>Ngày đặt</th>
                <th>Trạng thái</th>
                <th class="text-center">Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.Id</td>
                    <td>@item.HoTenNguoiNhan</td>
                    <td>@item.EmailNguoiDat</td>
                    <td>@item.SoDienThoai</td>
                    <td>@item.TongTien.ToString("N0") đ</td>
                    <td>@item.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="status-badge status-active">@item.TrangThai</span></td>
                    <td class="text-center">
                        <a asp-action="ChiTiet" asp-route-id="@item.Id" class="btn admin-primary-btn btn-sm">
                            Xem
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@model ConvenienceStore.Web.ViewModels.TaoTaiKhoanNhanVienViewModel

@{
    ViewData["Title"] = "Tạo tài khoản nhân viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-form-card">
    <div class="admin-page-header mb-4">
        <div>
            <h2>Tạo tài khoản nhân viên</h2>
            <p>Chỉ quản trị viên mới được phép tạo tài khoản nhân viên</p>
        </div>
    </div>

    @if (TempData["ThanhCong"] != null)
    {
        <div class="alert alert-success">@TempData["ThanhCong"]</div>
    }

    <form asp-action="TaoTaiKhoan" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="HoTen" class="form-label">Họ tên</label>
            <input asp-for="HoTen" class="form-control admin-input" />
            <span asp-validation-for="HoTen" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control admin-input" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MatKhau" class="form-label">Mật khẩu</label>
            <input asp-for="MatKhau" class="form-control admin-input" />
            <span asp-validation-for="MatKhau" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="XacNhanMatKhau" class="form-label">Xác nhận mật khẩu</label>
            <input asp-for="XacNhanMatKhau" class="form-control admin-input" />
            <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn admin-primary-btn">Tạo tài khoản nhân viên</button>
            <a asp-controller="QuanTri" asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
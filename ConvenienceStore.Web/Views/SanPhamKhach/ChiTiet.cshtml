@model ConvenienceStore.Web.ViewModels.ChiTietSanPhamKhachViewModel

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

@if (Model.SanPham != null)
{
    var duongDanAnhChinh = "/images/no-image.png";

    if (!string.IsNullOrWhiteSpace(Model.SanPham.HinhAnh))
    {
        if (Model.SanPham.HinhAnh.StartsWith("http://") || Model.SanPham.HinhAnh.StartsWith("https://"))
        {
            duongDanAnhChinh = Model.SanPham.HinhAnh;
        }
        else if (Model.SanPham.HinhAnh.StartsWith("/images/"))
        {
            duongDanAnhChinh = Model.SanPham.HinhAnh;
        }
        else
        {
            duongDanAnhChinh = "/images/" + Model.SanPham.HinhAnh;
        }
    }

    <div class="container py-4">
        <div class="admin-form-card mb-4">
            <div class="row g-4">
                <div class="col-md-5">
                    <img src="@duongDanAnhChinh"
                         alt="@Model.SanPham.TenSanPham"
                         class="img-fluid rounded"
                         style="width:100%; max-height:420px; object-fit:cover;" />
                </div>

                <div class="col-md-7">
                    <h2>@Model.SanPham.TenSanPham</h2>
                    <p class="text-muted mb-2">Danh mục: @Model.SanPham.DanhMuc?.TenDanhMuc</p>
                    <h3 style="color:#198754;">@Model.SanPham.Gia.ToString("N0") đ</h3>

                    <div class="mb-3">
                        <strong>Số lượng còn:</strong> @Model.SanPham.SoLuongTon
                    </div>

                    <div class="mb-4">
                        <strong>Mô tả:</strong>
                        <p class="mt-2">@Model.SanPham.MoTa</p>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <form asp-controller="GioHang" asp-action="ThemVaoGio" method="post">
                            <input type="hidden" name="sanPhamId" value="@Model.SanPham.Id" />
                            <input type="hidden" name="soLuong" value="1" />
                            <button type="submit" class="btn auth-btn">Thêm vào giỏ</button>
                        </form>

                        <a asp-controller="SanPham" asp-action="DatHang" asp-route-id="@Model.SanPham.Id" class="btn admin-primary-btn">
                            Mua ngay
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.SanPhamLienQuan.Any())
        {
            <section class="home-section">
                <h3 class="section-title">Sản phẩm liên quan</h3>

                <div class="product-row">
                    @foreach (var item in Model.SanPhamLienQuan)
                    {
                        var duongDanAnh = "/images/no-image.png";

                        if (!string.IsNullOrWhiteSpace(item.HinhAnh))
                        {
                            if (item.HinhAnh.StartsWith("http://") || item.HinhAnh.StartsWith("https://"))
                            {
                                duongDanAnh = item.HinhAnh;
                            }
                            else if (item.HinhAnh.StartsWith("/images/"))
                            {
                                duongDanAnh = item.HinhAnh;
                            }
                            else
                            {
                                duongDanAnh = "/images/" + item.HinhAnh;
                            }
                        }

                        <div class="product-card">
                            <div class="product-image">
                                <a asp-controller="SanPhamKhach" asp-action="ChiTiet" asp-route-id="@item.Id">
                                    <img src="@duongDanAnh" alt="@item.TenSanPham" />
                                </a>
                            </div>

                            <div class="product-body">
                                <div class="product-name">@item.TenSanPham</div>
                                <div class="price-wrap">
                                    <span class="product-price">@item.Gia.ToString("N0") đ</span>
                                </div>
                            </div>

                            <form asp-controller="GioHang" asp-action="ThemVaoGio" method="post">
                                <input type="hidden" name="sanPhamId" value="@item.Id" />
                                <input type="hidden" name="soLuong" value="1" />
                                <button type="submit" class="add-btn">+</button>
                            </form>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
}
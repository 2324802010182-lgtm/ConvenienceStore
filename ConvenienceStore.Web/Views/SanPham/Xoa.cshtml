@model ConvenienceStore.Models.Entities.SanPham

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-form-card">
    <div class="admin-page-header mb-4">
        <div>
            <h2>Xóa sản phẩm</h2>
            <p>Xác nhận xóa dữ liệu</p>
        </div>
    </div>

    <div class="alert alert-warning">
        Bạn có chắc muốn xóa sản phẩm này không?
    </div>

    <div class="mb-2">
        <strong>Tên sản phẩm:</strong> @Model.TenSanPham
    </div>

    <div class="mb-2">
        <strong>Giá:</strong> @Model.Gia.ToString("N0") đ
    </div>

    <div class="mb-4">
        <strong>Số lượng tồn:</strong> @Model.SoLuongTon
    </div>

    <form asp-action="Xoa" method="post">
        <input asp-for="Id" type="hidden" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn admin-danger-btn">Xóa</button>
            <a asp-action="Index" class="btn admin-secondary-btn">Hủy</a>
        </div>
    </form>
</div>
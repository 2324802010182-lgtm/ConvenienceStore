@model IEnumerable<ConvenienceStore.Models.Entities.SanPham>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Quản lý sản phẩm</h2>
        <p>Danh sách sản phẩm trong hệ thống</p>
    </div>
    <a asp-action="ThemMoi" class="btn admin-primary-btn">
        <i class="fa-solid fa-plus"></i> Thêm sản phẩm
    </a>
</div>

<div class="admin-table-card">
    <table class="table admin-table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng tồn</th>
                <th>Danh mục</th>
                <th>Trạng thái</th>
                <th>Khuyến mãi</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.TenSanPham</td>
                    <td>@item.Gia.ToString("N0") đ</td>
                    <td>@item.SoLuongTon</td>
                    <td>@item.DanhMuc?.TenDanhMuc</td>
                    <td>
                        @if (item.TrangThai)
                        {
                            <span class="status-badge status-active">Đang bán</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Ngưng bán</span>
                        }
                    </td>
                    <td>
                        @if (item.DangKhuyenMai)
                        {
                            <span class="status-badge status-active">-@item.PhanTramGiam%</span>
                        }
                        else if (item.PhanTramGiam > 0)
                        {
                            <span class="status-badge status-inactive">Đã cài KM</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Không</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="ChinhSua" asp-route-id="@item.Id" class="btn admin-warning-btn btn-sm">Sửa</a>
                        <a asp-action="Xoa" asp-route-id="@item.Id" class="btn admin-danger-btn btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
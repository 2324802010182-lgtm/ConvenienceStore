@model ConvenienceStore.Web.ViewModels.SanPhamViewModel

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-form-card">
    <div class="admin-page-header mb-4">
        <div>
            <h2>Chỉnh sửa sản phẩm</h2>
            <p>Cập nhật thông tin sản phẩm</p>
        </div>
    </div>

    <form asp-action="ChinhSua" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="TenSanPham" class="form-label">Tên sản phẩm</label>
            <input asp-for="TenSanPham" class="form-control admin-input" />
            <span asp-validation-for="TenSanPham" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MoTa" class="form-label">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control admin-input" rows="4"></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Gia" class="form-label">Giá</label>
                <input asp-for="Gia" class="form-control admin-input" />
                <span asp-validation-for="Gia" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="SoLuongTon" class="form-label">Số lượng tồn</label>
                <input asp-for="SoLuongTon" class="form-control admin-input" />
                <span asp-validation-for="SoLuongTon" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="HinhAnh" class="form-label">Đường dẫn hình ảnh</label>
            <input asp-for="HinhAnh" class="form-control admin-input" />
        </div>

        <div class="mb-3">
            <label asp-for="DanhMucId" class="form-label">Danh mục</label>
            <select asp-for="DanhMucId" asp-items="Model.DanhSachDanhMuc" class="form-select admin-input">
                <option value="">-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="DanhMucId" class="text-danger"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="TrangThai" class="form-check-input" />
            <label asp-for="TrangThai" class="form-check-label">Đang bán</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn admin-primary-btn">Cập nhật</button>
            <a asp-action="Index" class="btn admin-secondary-btn">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
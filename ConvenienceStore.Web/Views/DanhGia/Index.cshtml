@model IEnumerable<ConvenienceStore.Models.Entities.DanhGiaSanPham>

@{
    ViewData["Title"] = "Quản lý đánh giá";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Quản lý đánh giá sản phẩm</h2>
        <p>Ẩn hoặc hiển thị đánh giá của khách hàng</p>
    </div>
</div>

@if (TempData["ThanhCong"] != null)
{
    <div class="alert alert-success">@TempData["ThanhCong"]</div>
}

<div class="admin-table-card">
    <table class="table admin-table align-middle">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Người đánh giá</th>
                <th>Số sao</th>
                <th>Bình luận</th>
                <th>Ngày đánh giá</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SanPham?.TenSanPham</td>
                    <td>@(item.NguoiDung?.HoTen ?? item.NguoiDung?.Email)</td>
                    <td>@item.SoSao ⭐</td>
                    <td>@item.BinhLuan</td>
                    <td>@item.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.BiAn)
                        {
                            <span class="status-badge status-inactive">Đã ẩn</span>
                        }
                        else
                        {
                            <span class="status-badge status-active">Đang hiển thị</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (item.BiAn)
                        {
                            <form asp-action="HienDanhGia" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn admin-primary-btn btn-sm">Hiện</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="AnDanhGia" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn admin-danger-btn btn-sm">Ẩn</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
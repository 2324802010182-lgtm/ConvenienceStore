@model ConvenienceStore.Models.ViewModels.ThongKeBaoCaoViewModel

@{
    ViewData["Title"] = "Thống kê báo cáo";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2>Thống kê báo cáo</h2>
        <p>Doanh thu và hiệu suất bán hàng</p>
    </div>
</div>

<div class="dashboard-card-row mb-4">
    <div class="dashboard-card">
        <div class="dashboard-card-icon bg-green">
            <i class="fa-solid fa-sack-dollar"></i>
        </div>
        <div class="dashboard-card-info">
            <h3>@Model.TongDoanhThu.ToString("N0") đ</h3>
            <p>Tổng doanh thu</p>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="dashboard-card-icon bg-orange">
            <i class="fa-solid fa-cart-shopping"></i>
        </div>
        <div class="dashboard-card-info">
            <h3>@Model.TongDonDaGiao</h3>
            <p>Đơn đã giao</p>
        </div>
    </div>
</div>

<div class="dashboard-panel mb-4">
    <div class="dashboard-panel-header">
        <h4>Doanh thu theo ngày</h4>
    </div>
    <div class="dashboard-panel-body">
        <canvas id="chartNgay"></canvas>
    </div>
</div>

<div class="dashboard-grid mb-4">
    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Doanh thu theo tuần</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartTuan"></canvas>
        </div>
    </div>

    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Doanh thu theo tháng</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartThang"></canvas>
        </div>
    </div>
</div>

<div class="dashboard-grid mb-4">
    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Doanh thu theo quý</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartQuy"></canvas>
        </div>
    </div>

    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Doanh thu theo năm</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartNam"></canvas>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Sản phẩm bán chạy nhất</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartBanChay"></canvas>
        </div>
    </div>

    <div class="dashboard-panel">
        <div class="dashboard-panel-header">
            <h4>Sản phẩm bán chậm nhất</h4>
        </div>
        <div class="dashboard-panel-body">
            <canvas id="chartBanCham"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const nhanNgay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanDoanhThuTheoNgay));
        const duLieuNgay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuDoanhThuTheoNgay));

        const nhanTuan = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanDoanhThuTheoTuan));
        const duLieuTuan = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuDoanhThuTheoTuan));

        const nhanThang = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanDoanhThuTheoThang));
        const duLieuThang = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuDoanhThuTheoThang));

        const nhanQuy = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanDoanhThuTheoQuy));
        const duLieuQuy = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuDoanhThuTheoQuy));

        const nhanNam = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanDoanhThuTheoNam));
        const duLieuNam = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuDoanhThuTheoNam));

        const nhanBanChay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanSanPhamBanChay));
        const duLieuBanChay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuSanPhamBanChay));

        const nhanBanCham = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanSanPhamBanCham));
        const duLieuBanCham = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DuLieuSanPhamBanCham));

        function taoBieuDoDuong(id, labels, data, label) {
            new Chart(document.getElementById(id), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: data,
                        tension: 0.3,
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: true }
                    }
                }
            });
        }

        function taoBieuDoCot(id, labels, data, label) {
            new Chart(document.getElementById(id), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: data
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: true }
                    }
                }
            });
        }

        taoBieuDoDuong('chartNgay', nhanNgay, duLieuNgay, 'Doanh thu theo ngày');
        taoBieuDoDuong('chartTuan', nhanTuan, duLieuTuan, 'Doanh thu theo tuần');
        taoBieuDoDuong('chartThang', nhanThang, duLieuThang, 'Doanh thu theo tháng');
        taoBieuDoDuong('chartQuy', nhanQuy, duLieuQuy, 'Doanh thu theo quý');
        taoBieuDoDuong('chartNam', nhanNam, duLieuNam, 'Doanh thu theo năm');

        taoBieuDoCot('chartBanChay', nhanBanChay, duLieuBanChay, 'Số lượng bán');
        taoBieuDoCot('chartBanCham', nhanBanCham, duLieuBanCham, 'Số lượng bán');
    </script>
}